WECHAT_WEBHOOK_URL=
SHOW_CSLOG_SUMMARY=true
SHOW_CSLOG_PAGED=true
SHOW_CSLOG_DETAIL=true

# CSQAQ 库存监控
# 接口文档：https://docs.csqaq.com/api-358158458
# 填写后会按任务定时请求 /api/v1/task/get_task_business 并转发企业微信 markdown。
CSQAQ_API_TOKEN=

# 推荐填写 JSON 数组，每个对象对应一个库存监控任务。
# 示例：
# CSQAQ_INVENTORY_TASKS=[{"task_id":34,"name":"用户A-武器箱","search":"武器箱","type":"ALL","page_size":50,"max_pages":1},{"task_id":1431,"name":"用户B-全部动态","search":"","type":"ALL","page_size":50,"max_pages":1}]
CSQAQ_INVENTORY_TASKS=

# 简单模式：不填 CSQAQ_INVENTORY_TASKS 时，可用逗号分隔 task_id。
CSQAQ_INVENTORY_TASK_IDS=
CSQAQ_INVENTORY_SEARCH=
CSQAQ_INVENTORY_TYPE=ALL

CSQAQ_INVENTORY_INTERVAL_SECONDS=300
CSQAQ_INVENTORY_PAGE_SIZE=50
CSQAQ_INVENTORY_MAX_PAGES=1
CSQAQ_INVENTORY_BATCH_SIZE=10
CSQAQ_INVENTORY_SEND_INITIAL=false
CSQAQ_INVENTORY_STATE_FILE=logs/csqaq_inventory_state.json

# CSQAQ 文档目前只返回 type 数值，可按需覆盖成更可读文案。
# 示例：CSQAQ_INVENTORY_TYPE_LABELS={"4":"减少","5":"新增","7":"变动"}
CSQAQ_INVENTORY_TYPE_LABELS=
